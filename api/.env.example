APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=finance
DB_USERNAME=finance
DB_PASSWORD=secret

BROADCAST_DRIVER=reverb

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
CACHE_DRIVER=redis
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${REVERB_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# AI для анализа чеков: OpenAI (ChatGPT) или Groq (приоритет у OpenAI)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

GROQ_API_KEY=
# При ошибке cURL 77 (certificate verify) на Windows установите false
GROQ_VERIFY_SSL=true

# Web Push (VAPID) — сгенерировать: php artisan webpush:vapid
# Требуется PHP-расширение BCMath или GMP (в php.ini: extension=bcmath)
# Локально работает на localhost (HTTPS не нужен для localhost)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
