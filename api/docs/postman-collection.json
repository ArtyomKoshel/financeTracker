{
  "info": {
    "_postman_id": "finance-tracker-api-v2",
    "name": "Finance Tracker API",
    "description": "Полная коллекция API Finance Tracker. Установите переменную {{base_url}} = http://localhost:8000/api и {{token}} после логина.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Bootstrap",
      "item": [
        {
          "name": "Bootstrap",
          "request": { "method": "GET", "url": "{{base_url}}/bootstrap" }
        },
        {
          "name": "Me",
          "request": { "method": "GET", "url": "{{base_url}}/me" }
        },
        {
          "name": "Ping",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/ping" }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions?page=1&per_page=50&month=2026-03",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "50" },
                { "key": "month", "value": "2026-03", "disabled": true },
                { "key": "year", "value": "2026", "disabled": true },
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "tag", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create transaction",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"expense\",\n  \"amount\": 15.50,\n  \"category_id\": 1,\n  \"date\": \"2026-03-03\",\n  \"description\": \"Кофе\"\n}" }
          }
        },
        {
          "name": "Delete transaction",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/transactions?id=1"
          }
        },
        {
          "name": "Transactions by month",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/month?month=2026-03"
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/export?month=2026-03"
          }
        },
        {
          "name": "Bulk delete",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions/bulk-delete",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"ids\": [1, 2, 3]\n}" }
          }
        },
        {
          "name": "Bulk update",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions/bulk-update",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"ids\": [1, 2],\n  \"category_id\": 5\n}" }
          }
        },
        {
          "name": "Suggest category",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/suggest-category?description=Продукты+в+Евроопте"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "List tags",
          "request": { "method": "GET", "url": "{{base_url}}/tags" }
        },
        {
          "name": "Create tag",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tags",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"работа\",\n  \"color\": \"#3B82F6\"\n}" }
          }
        },
        {
          "name": "Delete tag",
          "request": { "method": "DELETE", "url": "{{base_url}}/tags/1" }
        },
        {
          "name": "Sync transaction tags",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions/1/tags",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tags\": [\"работа\", \"командировка\"]\n}" }
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "List budgets",
          "request": { "method": "GET", "url": "{{base_url}}/budgets?month=2026-03" }
        },
        {
          "name": "Set budget limit",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/budgets",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": 1,\n  \"month\": \"2026-03\",\n  \"amount\": 500\n}" }
          }
        },
        {
          "name": "Delete budget limit",
          "request": { "method": "DELETE", "url": "{{base_url}}/budgets?category_id=1&month=2026-03" }
        },
        {
          "name": "Copy budgets to next month",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/budgets/copy",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"from_month\": \"2026-03\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
